/**
 * GOOGLE DRIVE TO SUPABASE SYNC (WITH THUMBNAIL STORAGE)
 * Version: 3.1
 *
 * INSTRUCTIONS:
 * 1. Copy this entire file into script.google.com
 * 2. Enable "Drive API" in Services (+)
 * 3. Update FOLDER_ID, SUPABASE_URL, SUPABASE_KEY, and SUPABASE_TABLE
 * 4. Ensure a public Supabase Storage bucket named 'thumbnails' exists
 */-
// ─── CONFIGURATION ────────────────────────────────────────────────────────────

var FOLDER_ID      = "1p0xKH0vKfa_KjiY4J9MB--8sgeBzcUK6";
var USE_SHARED_DRIVE = true;
var BUCKET_NAME    = "thumbnails";

// Supabase credentials - REPLACE THESE
var SUPABASE_URL = "YOUR_SUPABASE_URL_HERE";
var SUPABASE_KEY = "YOUR_SUPABASE_KEY_HERE";
var SUPABASE_TABLE = "student_documents";

var BATCH_SIZE = 50; // Smaller batch for thumbnail processing

// ─── MAIN ENTRY POINT ─────────────────────────────────────────────────────────

function exportFolderLinks() {
  var rows = [];
  collectAllSharedDrive(FOLDER_ID, rows, getRootFolderName(FOLDER_ID));

  var fileRows = rows.filter(function(r) { return r[1] !== '📁 Folder'; });
  Logger.log('📦 Processing ' + fileRows.length + ' files...');

  var records = fileRows.map(function(r) {
    var driveId = r[10];
    var driveThumbnailLink = r[11];
    
    // FAST: Use Google Drive's native thumbnail link directly instead of uploading to Supabase Storage.
    // This avoids downloading/uploading every thumbnail synchronously, speeding up the script by 10x-100x.
    var thumbnailUrl = driveThumbnailLink ? "https://drive.google.com/thumbnail?id=" + driveId + "&sz=w600" : null;

    var parsedYear = parseInt(r[7], 10) || 0;
    
    return {
      title:        r[0],
      file_url:     r[2],
      folder_path:  r[4],
      student_year: parsedYear,
      block:        r[9] || 'Other',
      doc_type:     r[8] || 'Other',
      generation:   parseInt(r[5], 10) || 0,
      is_folder:    false,
      drive_id:     driveId,
      thumbnail_url: thumbnailUrl
    };
  });

  // Batch Upsert
  for (var i = 0; i < records.length; i += BATCH_SIZE) {
    upsertToSupabase(records.slice(i, i + BATCH_SIZE));
    Utilities.sleep(500); 
  }
}

// ─── STORAGE & SUPABASE ───────────────────────────────────────────────────────

// NOTE: This function is currently unused because using direct Google Drive thumbnails is much faster.
function uploadToSupabaseStorage(fileId, thumbnailUrl) {
  try {
    var imageBlob = UrlFetchApp.fetch(thumbnailUrl, {
      headers: { 'Authorization': 'Bearer ' + ScriptApp.getOAuthToken() }
    }).getBlob();

    var uploadUrl = SUPABASE_URL + '/storage/v1/object/' + BUCKET_NAME + '/' + fileId + '.webp';
    
    var response = UrlFetchApp.fetch(uploadUrl, {
      method: 'POST',
      contentType: 'image/webp',
      headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY },
      payload: imageBlob,
      muteHttpExceptions: true
    });

    if (response.getResponseCode() === 200) {
      return SUPABASE_URL + '/storage/v1/object/public/' + BUCKET_NAME + '/' + fileId + '.webp';
    }
    return null;
  } catch(e) { return null; }
}

function upsertToSupabase(records) {
  var url = SUPABASE_URL + '/rest/v1/' + SUPABASE_TABLE;
  UrlFetchApp.fetch(url, {
    method: 'POST',
    contentType: 'application/json',
    headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Prefer': 'resolution=merge-duplicates' },
    payload: JSON.stringify(records)
  });
}

// ─── DRIVE COLLECTION ─────────────────────────────────────────────

function getRootFolderName(id) {
  try { return Drive.Files.get(id, {supportsAllDrives:true}).name; } catch(e) { return "Root"; }
}

function collectAllSharedDrive(folderId, rows, path) {
  var pageToken = null;
  do {
    var result = Drive.Files.list({
      q: "'" + folderId + "' in parents and trashed = false",
      includeItemsFromAllDrives: true,
      supportsAllDrives: true,
      fields: "nextPageToken, files(id, name, mimeType, modifiedTime, webViewLink, thumbnailLink)",
      pageSize: 100,
      pageToken: pageToken
    });
    var files = result.files || [];
    for (var i = 0; i < files.length; i++) {
      var f = files[i];
      var isFolder = (f.mimeType === 'application/vnd.google-apps.folder');
      var subPath = path + ' > ' + f.name;
      var auto = detectFromPath(isFolder ? subPath : path, f.name);
      rows.push([f.name, isFolder ? '📁 Folder' : '📄 File', f.webViewLink, f.modifiedTime, path, auto.run, '', auto.year, auto.docType, auto.block, f.id, f.thumbnailLink]);
      if (isFolder) collectAllSharedDrive(f.id, rows, subPath);
    }
    pageToken = result.nextPageToken;
  } while (pageToken);
}

// ─── DETECTION LOGIC (OMITTED FOR BREVITY - KEEP YOUR EXISTING LOGIC) ─────────
// (Make sure to keep detectFromPath, detectDocType, detectBlockFromPath, guessYearFromBlock)
